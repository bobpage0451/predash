# IMAP ingestion settings (copy to .env and fill in)
IMAP_HOST=mail.eclipso.de
IMAP_PORT=993
IMAP_USER=you@eclipso.de
IMAP_PASS=your-password-here
IMAP_MAILBOX=INBOX
# EMAIL_SOURCE=eclipso:you@eclipso.de
# IMAP_LIMIT=50

# LLM processing settings
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=llama3.1:8b
PROCESSOR_NAME=ollama
PROMPT_VERSION=v1
OLLAMA_TIMEOUT_SECONDS=120
EMAIL_PROCESS_LIMIT=50

# Embedding settings
EMBEDDING_MODEL=nomic-embed-text
EMBEDDING_DIMS=768
